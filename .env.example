NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Use the full site origin in production, e.g. https://www.grupogscapital.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CreativeRafaSuperSecretKeyThatShouldBeChangedInProduction

# Admin credentials (CredentialsProvider)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Database (Prisma Postgres)
# Pooling/Accelerate URL used by Prisma Client
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY
# Direct connection URL used by Prisma Migrate (optional but recommended)
DIRECT_URL=postgresql://user:password@localhost:5432/gsac_db

#blob storage (vercel)
BLOB_STORE_ID="store_tokengivenbyprovider"
BLOB_READ_WRITE_TOKEN="vercel_blob_longtokengivenbyprovider"